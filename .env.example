# ============================================================
# 竞争情报工具包 — 环境配置文件
# ============================================================
# 使用说明：
#   1. 复制本文件并重命名为 .env
#   2. 填入你自己的 API Key 和配置项
#   3. 切勿将 .env 文件提交到版本控制系统（已在 .gitignore 中排除）
# ============================================================


# ------------------------------------------------------------
# AI 研究工具
# ------------------------------------------------------------

# 智谱AI GLM API（全流程统一使用，兼容 OpenAI SDK）
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 模型：GLM-4.6V-FlashX（代码内默认）
# Key 1 → Step 1 景观综合
ZHIPU_API_KEY_1=

# Key 2 → Step 2 叙事分析 + Step 3 空白映射
ZHIPU_API_KEY_2=

# Key 3 → Step 4 销售赋能 + Step 5 监控
ZHIPU_API_KEY_3=

# Key 4 → 可选；深度报告按章节轮转时会与 1–3 一起参与负载均衡
ZHIPU_API_KEY_4=


# ------------------------------------------------------------
# 竞争监控工具
# ------------------------------------------------------------

# Google Alerts（通过 RSS 订阅，无需 Key，填写 RSS Feed URL）
# 示例：https://www.google.com/alerts/feeds/{your_id}/{alert_id}
GOOGLE_ALERTS_RSS_URL=

# Crunchbase API（用于融资轮次监控）
# 获取地址：https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=


# ------------------------------------------------------------
# CRM 集成（胜负分析数据来源）
# ------------------------------------------------------------

# Salesforce（可选）
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# HubSpot（可选）
# 获取地址：https://developers.hubspot.com/
HUBSPOT_API_KEY=

# Pipedrive（可选）
PIPEDRIVE_API_TOKEN=


# ------------------------------------------------------------
# 数据存储与输出
# ------------------------------------------------------------

# Notion API（用于将分析结果写入 Notion 数据库）
# 获取地址：https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google Sheets API（用于信号追踪器电子表格）
# 获取地址：https://console.cloud.google.com/
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Airtable（可选替代方案）
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=


# ------------------------------------------------------------
# 通知与分发
# ------------------------------------------------------------

# Slack Webhook（用于推送每月竞争简报到频道）
# 获取地址：https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#competitive-intel

# 邮件通知（SMTP，用于发送报告）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=


# ------------------------------------------------------------
# 应用基础配置
# ------------------------------------------------------------

# 运行环境：development | staging | production
NODE_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 监控刷新频率（单位：天）
MONITORING_INTERVAL_DAYS=30

# 默认分析市场 / 产品类别（可在每次运行时覆盖）
DEFAULT_MARKET=
DEFAULT_PRODUCT_CATEGORY=

# ── 竞争对手输入方式（二选一）───────────────────────────────
#
# 方式 1【推荐】：结构化 JSON 文件
#   复制 competitors_input.json，填写竞争对手名称、官网文案、销售笔记等详细信息
#   运行：python main.py --input competitors_input.json
#   若项目根目录存在 competitors_input.json，工具会自动加载，无需 --input 参数
#
# 方式 2：快速名称列表（仅名称，无详细信息）
#   适合快速测试，叙事分析将使用占位符，提示用户手动补充文案
#   示例：CompetitorA,CompetitorB,CompetitorC
COMPETITOR_LIST=
